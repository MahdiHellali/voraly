# ─── Voraly · environment template ────────────────────────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored — NEVER commit keys.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public (safe in the browser — security is enforced by RLS):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# SERVER-ONLY. Bypasses RLS. Used exclusively by the Whop webhook
# (src/app/api/webhooks/whop/route.ts) via src/lib/supabase/admin.ts.
# Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Whop (payments) ───────────────────────────────────────────────────────────
# SERVER-ONLY. Whop dashboard → Developer → API keys (company key).
WHOP_API_KEY=whop_...

# SERVER-ONLY. Whop dashboard → Developer → Webhooks → your endpoint's secret.
# Endpoint URL to register: https://YOUR-DOMAIN/api/webhooks/whop
# (local testing: expose with a tunnel, e.g. `ngrok http 3000`)
WHOP_WEBHOOK_SECRET=...

# Public plan identifier for the "Voraly Pro" plan (create the plan once in the
# Whop dashboard, then paste its id). Plan ids are public by design — the
# checkout embed needs it client-side.
NEXT_PUBLIC_WHOP_PLAN_ID=plan_...

# Optional: your Whop company id (biz_...). Not used by the current plan_id
# checkout flow; reserved for future API calls that require it.
NEXT_PUBLIC_WHOP_COMPANY_ID=biz_...

# ── OAuth plateformes (existing) ──────────────────────────────────────────────
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
# UPWORK_CLIENT_ID=...
# UPWORK_CLIENT_SECRET=...

# Optional: absolute origin used to build OAuth redirect URIs (defaults to
# http://localhost:3000).
# NEXT_PUBLIC_SITE_URL=https://voraly.me
