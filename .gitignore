# ─── Voraly monorepo · root safety-net ignores ───────────────────────────────
# Per-package .gitignore files (voraly-web, supabase) still apply within their
# folders; these rules guarantee coverage across the whole repo.

# Dependencies
node_modules/

# Build output / caches
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo

# Secrets & local env (NEVER commit) — keep .env.example if one is added
.env
.env.*
!.env.example

# Production secrets file for the deploy stack (real values, never commit)
deploy/.env.production
!deploy/.env.production.example

# Supabase CLI temp (project ref, org id, email)
.temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp

# Extension local Supabase config (real anon key) — use supabase-config.example.js
extension/supabase-config.js

# VPS credentials — NEVER commit
ssh.txt
