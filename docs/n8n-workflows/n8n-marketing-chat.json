        "typeVersion": 3.4,
        "position": [
          224,
          112
        ]
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "=Conversation: {{ $json.history }}\n\nFreelance: {{ $json.message }}",
          "hasOutputParser": true,
          "options": {
            "systemMessage": "=Tu es le conseiller marketing exclusif de Voraly pour freelances.\nContexte strategie: {{ $json.marketing_strategy }}\n\nReponds uniquement aux questions de marketing freelance (acquisition clients, reseaux sociaux, contenu, branding). Retourne UNIQUEMENT du JSON valide selon le schema fourni — pas de markdown."
          }
        },
