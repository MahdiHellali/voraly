                "value": "={{ JSON.stringify($json.body?.history ?? $json.history ?? []) }}",
                "type": "string"
              },
              {
                "id": "assign-strategy",
                "name": "marketing_strategy",
                "value": "={{ JSON.stringify($json.body?.marketing_strategy ?? $json.marketing_strategy ?? {}) }}",
                "type": "string"
              }
            ]
          },
          "options": {}
        },
        "id": "set-v3",
        "name": "Normalize Input",
