# Voraly production environment template.
# Copy to `.env.production` and fill in real values. NEVER commit the real file.

# ---- Supabase (cloud) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Whop (payments) ----
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret
NEXT_PUBLIC_WHOP_PLAN_ID=plan_xxxxxxxx
NEXT_PUBLIC_WHOP_COMPANY_ID=biz_xxxxxxxx

# ---- Domaines (Caddy TLS) ----
SITE_DOMAIN=voraly.net
N8N_DOMAIN=n8n.voraly.net
# Matomo analytics (Caddy gere son cert Let's Encrypt).
MATOMO_DOMAIN=stats.voraly.net

# ---- Matomo (analytics self-hosted) ----
# Mots de passe DB forts (jamais commites). matomo-db = MariaDB.
MATOMO_DB_PASSWORD=change-me-to-a-strong-password
MATOMO_DB_ROOT_PASSWORD=change-me-to-another-strong-password
# Verrou de la fenetre d'installation Matomo (basic auth Caddy). Generer le hash :
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'mon-mot-de-passe'
MATOMO_SETUP_USER=admin
MATOMO_SETUP_HASH=replace-with-bcrypt-hash-from-caddy-hash-password

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://voraly.net

# ---- n8n roadmap webhook ----
N8N_ROADMAP_WEBHOOK_URL=https://n8n.voraly.net/webhook/generate-roadmap

# ---- n8n basic auth + encryption ----
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-to-a-strong-password
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ---- LinkedIn OAuth ----
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ---- Google Calendar OAuth (SERVER-ONLY) ----
# Redirect URI à enregistrer dans Google Cloud Console :
#   https://voraly.net/api/integrations/google_calendar/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Notion OAuth (SERVER-ONLY) ----
# Redirect URI à enregistrer dans les paramètres de l'intégration Notion publique :
#   https://voraly.net/api/integrations/notion/callback
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
